# AI Image Composer local DB host port mapping.
# Default is 55432 to avoid clashing with existing local Postgres on 5432.
AIIC_POSTGRES_PORT=55432

# Optional explicit database URL override for API and Alembic.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:55432/ai_image_composer

# API abuse protection defaults (per-client host).
AIIC_RATE_LIMIT_ENABLED=true
AIIC_RATE_LIMIT_WINDOW_SECONDS=60
AIIC_RATE_LIMIT_MAX_REQUESTS=120
# Comma-separated API paths exempt from rate limiting.
AIIC_RATE_LIMIT_EXEMPT_PATHS=/health
